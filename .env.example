# =============================================================================
# ARCHIVO DE EJEMPLO DE VARIABLES DE ENTORNO
# Copia este archivo como .env y completa los valores reales.
# NUNCA versiones el archivo .env en git.
# =============================================================================

# -------------------------
# ENTORNO Y NAVEGADOR
# -------------------------
# Ambiente de ejecución (admin, app, test1..test7, smoke, saas, saas2)
ENV=test5

# Navegador a utilizar: chromium | firefox | webkit
BROWSER=chromium

# Modo headless: true | false
HEADLESS=false

# -------------------------
# CREDENCIALES DE SUPERADMIN
# -------------------------
EMAIL=superadmin@comunidadfeliz.cl
PASSWORD=Aa123456.

# Contraseña opcional (Webpay, banco, etc.)
OPTIONAL_PASSWORD=

# Contraseña de conexión bancaria
BANK_CONNECTION=

# Contraseña inicial asignada al administrador de comunidad al crearlo
ADMIN_INITIAL_PASSWORD=Aa123456.

# -------------------------
# GOOGLE SHEETS / DRIVE
# -------------------------
# Ruta relativa al archivo JSON de credenciales de Service Account
GOOGLE_CREDENTIALS_PATH=src/config/credentials/automationcf-credential-db.json

# Nombre del archivo de Google Sheets en Google Drive (nombre exacto)
GOOGLE_SHEETS_DB_NAME=AutomationCF_DataBase_CC
